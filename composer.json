{
    "name": "moe/laravel-finance",
    "description": "Finance module for MOE ecosystem — Wallet, Payment, Refund",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "MindOfEmanizer",
            "email": "emanizer@example.com"
        }
    ],
    "keywords": ["laravel", "finance", "wallet", "payment", "refund", "moe"],
    "autoload": {
        "psr-4": {
            "Moe\\Finance\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moe\\Finance\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0",
        "moe/laravel-core": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moe\\Finance\\FinanceServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
